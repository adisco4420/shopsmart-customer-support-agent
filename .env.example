# ── Required ──────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Optional ──────────────────────────────────────────────
# Model to use via OpenRouter (default: anthropic/claude-sonnet-4.6)
# Other good options: openai/gpt-4o, google/gemini-pro-1.5, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Public URL of your deployed app (sent in OpenRouter request headers)
APP_URL=https://your-app.onrender.com

# Set to "development" for hot-reload during local dev
ENV=production

# Server port (default: 8000)
PORT=8000

# ── Langfuse (LLM observability) — optional but recommended ───────────────
# Get keys at: https://cloud.langfuse.com  (or point to your self-hosted instance)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Default host is https://cloud.langfuse.com — override for self-hosted:
# LANGFUSE_HOST=https://your-langfuse.example.com
